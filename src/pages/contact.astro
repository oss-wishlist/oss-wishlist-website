---
import Layout from '../components/Layout.astro';
import { getBasePath } from '../lib/paths';

const basePath = getBasePath();
---

<Layout title="Get in Touch - Open Source Wishlist" description="Contact the Open Source Wishlist team with questions, feedback, or partnership inquiries.">
  <div class="max-w-2xl mx-auto px-4 py-12">
    <!-- Header -->
    <div class="text-center mb-10">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Get in Touch</h1>
      <p class="text-lg text-gray-600">Have a question, feedback, or want to get involved? We'd love to hear from you.</p>
    </div>

    <!-- Status messages (shown/hidden by JS) -->
    <div id="form-success" class="alert-success mb-8 hidden" role="alert">
      <p class="font-semibold">Message sent!</p>
      <p>Thanks for reaching out. We'll get back to you as soon as we can.</p>
    </div>
    <div id="form-error" class="alert-error mb-8 hidden" role="alert">
      <p class="font-semibold">Something went wrong.</p>
      <p id="form-error-text">We couldn't send your message. Please try again.</p>
    </div>

    <form
      id="contact-form"
      class="bg-white rounded-lg border border-gray-200 shadow-sm p-8 space-y-6"
      novalidate
    >
      <div>
        <label for="name" class="form-label">
          Name <span class="field-required">*</span>
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          autocomplete="name"
          class="form-input"
          placeholder="Your name"
        />
      </div>

      <div>
        <label for="email" class="form-label">
          Email <span class="field-required">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          class="form-input"
          placeholder="your@email.com"
        />
      </div>

      <div>
        <label for="subject" class="form-label">
          Subject <span class="field-required">*</span>
        </label>
        <select id="subject" name="subject" required class="form-input">
          <option value="">Select a topic…</option>
          <option value="Workshops">Workshops &amp; Training</option>
          <option value="Practitioners">Becoming a Practitioner</option>
          <option value="Maintainers">Help for Maintainers</option>
          <option value="Services">Services &amp; Offerings</option>
          <option value="Something Else">Something Else</option>
        </select>
      </div>

      <div>
        <label for="message" class="form-label">
          Message <span class="field-required">*</span>
        </label>
        <textarea
          id="message"
          name="message"
          required
          rows="6"
          class="form-input resize-y"
          placeholder="Tell us how we can help…"
        ></textarea>
        <p id="message-error" class="hidden text-sm text-gray-500 mt-1" role="alert"></p>
      </div>

      <!-- Honeypot: hidden from real users, bots fill it -->
      <div style="position:absolute;left:-9999px;top:-9999px;width:1px;height:1px;overflow:hidden;" aria-hidden="true">
        <label for="_hp">Leave this empty</label>
        <input type="text" id="_hp" name="_hp" tabindex="-1" autocomplete="off" />
      </div>
      <!-- Page-load timestamp for timing check -->
      <input type="hidden" id="_ts" name="_ts" value="" />

      <div class="pt-2">
        <button type="submit" id="submit-btn" class="btn-sparkle w-full">
          <svg class="btn-sparkle-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          <span class="btn-sparkle-text" id="submit-label">Send Message</span>
          <div class="btn-sparkle-particles">
            <span class="sparkle-particle" style="top:20%;left:20%;background:rgb(196,181,253);animation:sparkle-burst-1 600ms ease-out forwards;"></span>
            <span class="sparkle-particle" style="top:60%;left:70%;background:rgb(167,139,250);animation:sparkle-burst-2 600ms ease-out forwards;"></span>
            <span class="sparkle-particle" style="top:80%;left:40%;background:rgb(217,213,254);animation:sparkle-burst-3 600ms ease-out forwards;"></span>
          </div>
        </button>
      </div>
    </form>
  </div>
</Layout>

<script define:vars={{ basePath }}>
  const form = document.getElementById('contact-form');
  const successBox = document.getElementById('form-success');
  const errorBox = document.getElementById('form-error');
  const errorText = document.getElementById('form-error-text');
  const submitBtn = document.getElementById('submit-btn');
  const submitLabel = document.getElementById('submit-label');

  // Pre-select subject from URL param (e.g. ?subject=Workshops)
  const preSubject = new URLSearchParams(window.location.search).get('subject');
  if (preSubject) {
    const select = form.querySelector('#subject');
    const match = Array.from(select.options).find(o => o.value === preSubject);
    if (match) select.value = preSubject;
  }

  function showError(msg) {
    errorText.textContent = msg;
    errorBox.classList.remove('hidden');
    successBox.classList.add('hidden');
    errorBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function showSuccess() {
    successBox.classList.remove('hidden');
    errorBox.classList.add('hidden');
    form.reset();
    successBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // Set page-load timestamp for server-side timing check
  document.getElementById('_ts').value = Date.now().toString();

  function clearFieldErrors() {
    form.querySelectorAll('[id$="-error"]').forEach(el => {
      el.textContent = '';
      el.classList.add('hidden');
    });
  }

  function showFieldError(fieldId, msg) {
    const el = document.getElementById(fieldId + '-error');
    if (el) {
      el.textContent = msg;
      el.classList.remove('hidden');
    }
  }

  form.addEventListener('submit', async function (e) {
    e.preventDefault();
    clearFieldErrors();

    const name = form.querySelector('#name').value.trim();
    const email = form.querySelector('#email').value.trim();
    const subject = form.querySelector('#subject').value;
    const message = form.querySelector('#message').value.trim();

    if (!name || !email || !subject || !message) {
      showError('Please fill in all required fields.');
      return;
    }

    if (message.length < 10) {
      showFieldError('message', 'Please write a little more so we can help you (at least 10 characters).');
      return;
    }

    submitBtn.disabled = true;
    submitLabel.textContent = 'Sending…';

    try {
      const data = new FormData();
      data.append('name', name);
      data.append('email', email);
      data.append('subject', subject);
      data.append('message', message);

      const res = await fetch(`${basePath}api/contact`, { method: 'POST', body: data });

      let result;
      try {
        result = await res.json();
      } catch {
        const bodyText = await res.text().catch(() => '(unreadable)');
        console.error('[contact form] non-JSON response', res.status, bodyText.slice(0, 500));
        showError(`Unexpected server response (HTTP ${res.status}). Please try again.`);
        return;
      }

      if (result.success) {
        showSuccess();
      } else if (result.code === 'moderation') {
        showError('Your message contains content that could not be accepted. Please revise and try again.');
      } else if (result.code === 'validation' && result.errors) {
        // Show field-level messages instead of a generic error
        const errors = result.errors;
        if (errors.message) showFieldError('message', errors.message[0]);
        else {
          const first = Object.values(errors).flat()[0];
          showError(first || 'Please check your entries and try again.');
        }
      } else {
        showError('We couldn\'t send your message. Please try again.');
      }
    } catch {
      showError('A network error occurred. Please check your connection and try again.');
    } finally {
      submitBtn.disabled = false;
      submitLabel.textContent = 'Send Message';
    }
  });
</script>
