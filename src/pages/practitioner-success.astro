---
import { getBasePath } from '../lib/paths';
import Layout from '../components/Layout.astro';

const basePath = getBasePath();
---

<Layout title="Application Submitted - OSS Wishlist" description="Your practitioner application has been successfully submitted">
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-lg shadow-sm border p-8 text-center">
        <!-- Success Icon -->
        <div class="mb-6">
          <svg class="w-16 h-16 text-gray-600 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>

        <!-- Success Message -->
        <h1 class="text-3xl font-bold text-gray-900 mb-4">
          Application Submitted Successfully!
        </h1>
        <p class="text-lg text-gray-600 mb-8">
          Thank you for joining as a practitioner. We'll review your application and get back to you soon.
        </p>

        <!-- Next Steps -->
        <div class="bg-gray-50 rounded-lg p-6 mb-8 text-left">
          <h2 class="text-xl font-semibold text-gray-900 mb-4">What Happens Next?</h2>
          <ol class="space-y-3 text-gray-700">
            <li class="flex items-start">
              <span class="flex-shrink-0 w-6 h-6 bg-gray-200 text-gray-700 rounded-full flex items-center justify-center text-sm font-semibold mr-3">1</span>
              <span>Our team will review your application (typically within 3-5 business days)</span>
            </li>
            <li class="flex items-start">
              <span class="flex-shrink-0 w-6 h-6 bg-gray-200 text-gray-700 rounded-full flex items-center justify-center text-sm font-semibold mr-3">2</span>
              <span>We'll verify your expertise and experience</span>
            </li>
            <li class="flex items-start">
              <span class="flex-shrink-0 w-6 h-6 bg-gray-200 text-gray-700 rounded-full flex items-center justify-center text-sm font-semibold mr-3">3</span>
              <span>You'll receive an email with next steps or any questions we might have</span>
            </li>
            <li class="flex items-start">
              <span class="flex-shrink-0 w-6 h-6 bg-gray-200 text-gray-700 rounded-full flex items-center justify-center text-sm font-semibold mr-3">4</span>
              <span>Once approved, your profile will be added to our practitioner directory</span>
            </li>
          </ol>
        </div>

        <!-- Helpful Resources -->
        <div class="bg-gray-100 border border-gray-300 rounded-lg p-6 mb-8 text-left">
          <h2 class="text-xl font-semibold text-gray-900 mb-4">Helpful Resources</h2>
          <div class="space-y-3">
            <a href={`${basePath}faq`} class="flex items-center text-gray-700 hover:text-gray-900 font-medium">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span>Frequently Asked Questions</span>
            </a>
            <a href={`${basePath}catalog`} class="flex items-center text-gray-700 hover:text-gray-900 font-medium">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
              </svg>
              <span>Browse Service Catalogue</span>
            </a>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={basePath} class="bg-gray-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-gray-700 transition-colors">
            Return to Home
          </a>
          <a href={`${basePath}practitioners`} class="badge-pending px-8 py-3 rounded-lg font-semibold hover:opacity-80 transition-opacity">
            Browse Practitioners
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
