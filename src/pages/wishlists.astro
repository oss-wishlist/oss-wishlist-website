---
import Layout from '../components/Layout.astro';
import { getBasePath } from '../lib/paths';

const basePath = getBasePath();
const user = Astro.locals.user;
---

<Layout 
  title="Wishlists | Open Source Wishlist" 
  description="Browse open source project wishlists or manage your own.">
  
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-gray-50 to-gray-100 py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-5xl font-bold text-gray-900 mb-4">
        OSS <span class="text-accent">Wishlists</span>
      </h1>
      <p class="text-xl text-gray-700 max-w-3xl mx-auto">
        Maintainers declare their project needs. Funders make it possible. Practitioners do the work.
      </p>
    </div>
  </section>

  <!-- Two Cards -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="grid md:grid-cols-2 gap-8">
      
      <!-- Browse Wishlists -->
      <a 
        href={`${basePath}browse-wishlists`}
        class="bg-white p-8 rounded-lg shadow-sm border-2 border-purple-200 flex flex-col hover:border-purple-400 hover:shadow-md transition-all duration-200 no-underline group"
        aria-label="Browse all wishlists"
      >
        <h2 class="text-2xl font-semibold text-purple-700 mb-3">Browse Wishlists</h2>
        <p class="text-gray-700 mb-6 flex-grow">Discover open source projects seeking support for governance, funding, security, and more. Find a wish you can help fulfill.</p>
        <span class="text-gray-700 group-hover:text-gray-900 font-medium">Browse all wishlists →</span>
      </a>

      <!-- My Wishlists -->
      <a 
        href={`${basePath}maintainers`}
        class="bg-white p-8 rounded-lg shadow-sm border-2 border-gray-200 flex flex-col hover:border-gray-400 hover:shadow-md transition-all duration-200 no-underline group"
        aria-label="My wishlists"
      >
        <h2 class="text-2xl font-semibold text-purple-700 mb-3">My Wishlists</h2>
        <p class="text-gray-700 mb-6 flex-grow">Create a new wishlist for your open source project, or view and manage the ones you've already created.</p>
        <span class="text-gray-700 group-hover:text-gray-900 font-medium">View or create wishlists →</span>
      </a>

    </div>
  </section>
</Layout>
