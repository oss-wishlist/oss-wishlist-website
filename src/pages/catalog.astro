---
import { getBasePath } from '../lib/paths';
const basePath = getBasePath();
import Layout from '../components/Layout.astro';
import { getCollection } from 'astro:content';
import { getApprovedPractitioners } from '../lib/db';

const servicesRaw = await getCollection('services');

let practitioners: { name: string; slug: string; services: string[] }[] = [];
try {
  const allPractitioners = await getApprovedPractitioners();
  practitioners = allPractitioners.map(p => ({ name: p.name, slug: p.slug, services: p.services }));
} catch {
  // db unavailable — dropdown will just be empty
}
// Sort services: featured first in defined order, then alphabetically
const featuredOrder = [
  'digital-sovereignty',
  'leadership-onboarding',
  'governance-setup',
  'moderation-strategy',
  'winding-down',
];
const services = servicesRaw.sort((a, b) => {
  const aIdx = featuredOrder.indexOf(a.slug);
  const bIdx = featuredOrder.indexOf(b.slug);
  if (aIdx !== -1 && bIdx !== -1) return aIdx - bIdx;
  if (aIdx !== -1) return -1;
  if (bIdx !== -1) return 1;
  return a.data.title.localeCompare(b.data.title);
});
const playbooks = await getCollection('playbooks-external');

// Map service slugs to playbook slugs (fallbacks for legacy mismatches)
const serviceToPlaybook: Record<string, string> = {
  'dependency-security-audit': 'security-audit',
  'governance-setup': 'project-and-community-governance',
  'leadership-onboarding': 'succession-planning',
  'funding-strategy': 'funding-strategy',
  'maintainer-task-contributor': 'maintainer-relief',
};

// Helper: prefer frontmatter linkage (playbook.data.service === service.slug), fallback to manual map
function getPlaybookForService(serviceSlug: string) {
  const direct = playbooks.find((p) => p.data.service === serviceSlug);
  if (direct) return direct;
  const mappedSlug = serviceToPlaybook[serviceSlug];
  return mappedSlug ? playbooks.find((p) => p.slug === mappedSlug) : null;
}
---

<Layout 
  title="Open Source Sustainability Services | OSS Wishlist" 
  description="Browse open source sustainability services: governance setup, funding strategy, security audits, succession planning, moderation, and more. Match with a verified practitioner.">
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-5xl font-bold text-gray-900 mb-4">Catalogue of <span class="text-accent">Services</span> & Resources</h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Browse <b>services</b> (expert help for sustainability challenges) and <b>resources</b> (funding needs like infrastructure and tooling). Filter by type or search by <b>practitioner</b> below.
        </p>
      </div>

      <!-- Type and Ecosystem Filters -->
      <div class="mb-8 space-y-4">
        <!-- Type Filter -->
        <div class="text-center">
          <div class="flex flex-wrap justify-center gap-2 items-center">
            <button class="type-filter-btn active badge-pending px-6 py-3 rounded-lg text-sm font-medium" 
                    data-type="all">
              All
            </button>
            <button class="type-filter-btn px-6 py-3 rounded-lg text-sm font-medium bg-white text-gray-700 border border-gray-300 hover:bg-gray-50" 
                    data-type="service">
              Services
            </button>
            <button class="type-filter-btn px-6 py-3 rounded-lg text-sm font-medium bg-white text-gray-700 border border-gray-300 hover:bg-gray-50" 
                    data-type="resource">
              Resources
            </button>
            {practitioners.length > 0 && (
              <select id="practitioner-filter"
                      class="px-4 py-3 rounded-lg text-sm font-medium bg-white text-gray-700 border border-gray-300 hover:bg-gray-50 cursor-pointer">
                <option value="">Filter by Practitioner</option>
                {practitioners.map(p => (
                  <option value={p.slug}>{p.name}</option>
                ))}
              </select>
            )}
          </div>
        </div>

      </div>

  <!-- Services & Generic Funding Campaign Card Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" id="services-grid">
        {services.map((service) => {
          const playbook = getPlaybookForService(service.slug);
          return (
          <div class={`service-card p-6 rounded-lg shadow-sm border hover:shadow-md transition-shadow ${
            service.slug === 'general-need' ? 'bg-purple-50' : 'bg-white'
          }`}
               data-type={service.data.type}
               data-slug={service.slug}>
            <div class="flex justify-between items-start mb-4">
              <div>
                <h3 class="text-xl font-semibold text-gray-900">
                  {service.data.title}
                </h3>
                <div class="flex items-center gap-2 mt-1">
                  <span class={`inline-block px-2 py-1 text-xs font-medium rounded-full ${
                    service.data.type === 'resource' 
                      ? 'bg-gray-200 text-gray-800' 
                      : 'bg-gray-100 text-gray-700'
                  }`}>
                    {service.data.type === 'resource' ? 'Resource' : 'Service'}
                  </span>
                  {service.data.available === false && (
                    <span class="inline-block px-2 py-1 text-xs font-medium bg-gray-300 text-gray-700 rounded-full">
                      Currently Unavailable
                    </span>
                  )}
                </div>
              </div>
            </div>
            
            <p class="text-gray-600 mb-4">
              {service.data.description}
            </p>
            {service.data.impact && (
              <div class="text-sm text-gray-700 mb-4">
                <span class="font-semibold">Sponsor and Ecosystem Impact:</span> {service.data.impact}
              </div>
            )}
            
            {service.data.available === false && service.data.unavailable_reason && (
              <p class="text-xs text-gray-500 italic mb-4">{service.data.unavailable_reason}</p>
            )}

            <div class="pt-4 border-t flex gap-3 items-center">
              <a href={`${basePath}services/${service.slug}`} 
                 class="inline-flex items-center gap-1 badge-pending px-4 py-2 rounded-lg font-medium hover:opacity-80 transition-opacity text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Learn more
              </a>
              {service.data.available === false && service.data.type !== 'resource' && (
                <a href={`${basePath}apply-practitioner`}
                   class="inline-flex items-center gap-1 text-sm text-gray-600 hover:text-gray-900 font-medium transition-colors">
                  Practitioners needed →
                </a>
              )}
              {service.data.available === false && service.data.type === 'resource' && (
                <span class="text-sm text-gray-500 italic">Funding needed</span>
              )}
            </div>
          </div>
        )})}
      </div>

      <!-- Call to Action -->
      <div class="text-center mt-16">
        <div class="bg-white p-8 rounded-lg shadow-sm border">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">
            Ready to get sustainability support for your project?
          </h2>
          <p class="text-gray-600 mb-6">
            Create a wishlist with the sustainability services you need and share it with your community
          </p>
          <a href={`${basePath}create-wishlist`} 
             class="bg-gray-900 text-white px-8 py-3 rounded-lg font-semibold hover:bg-gray-800 transition-colors">
            Create Your Wishlist
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ practitioners }}>
  document.addEventListener('DOMContentLoaded', function() {
    const typeFilterButtons = document.querySelectorAll('.type-filter-btn');
    const serviceCards = document.querySelectorAll('.service-card');
    const practitionerSelect = document.getElementById('practitioner-filter');

    let currentType = 'all';
    let currentPractitioner = '';

    // Build a map: serviceSlug -> array of practitioner slugs that offer it
    const servicesPractitionerMap = {};
    practitioners.forEach(p => {
      p.services.forEach(serviceSlug => {
        if (!servicesPractitionerMap[serviceSlug]) servicesPractitionerMap[serviceSlug] = [];
        servicesPractitionerMap[serviceSlug].push(p.slug);
      });
    });

    function filterCards() {
      serviceCards.forEach(card => {
        const cardType = card.getAttribute('data-type');
        const cardSlug = card.getAttribute('data-slug');
        const typeMatch = currentType === 'all' || cardType === currentType;
        const practitionerMatch = !currentPractitioner ||
          (servicesPractitionerMap[cardSlug] || []).includes(currentPractitioner);

        card.style.display = (typeMatch && practitionerMatch) ? 'block' : 'none';
      });
    }

    function updateURL() {
      const params = new URLSearchParams(window.location.search);
      if (currentPractitioner) {
        params.set('practitioner', currentPractitioner);
      } else {
        params.delete('practitioner');
      }
      const newURL = params.toString()
        ? `${window.location.pathname}?${params.toString()}`
        : window.location.pathname;
      history.replaceState(null, '', newURL);
    }

    // Pre-populate practitioner filter from URL on load
    const initialParams = new URLSearchParams(window.location.search);
    const practitionerFromQuery = initialParams.get('practitioner');
    if (practitionerFromQuery && practitionerSelect) {
      const matchingOption = practitionerSelect.querySelector(`option[value="${CSS.escape(practitionerFromQuery)}"]`);
      if (matchingOption) {
        practitionerSelect.value = practitionerFromQuery;
        currentPractitioner = practitionerFromQuery;
        filterCards();
      }
    }

    // Type filtering
    typeFilterButtons.forEach(button => {
      button.addEventListener('click', () => {
        currentType = button.getAttribute('data-type');

        typeFilterButtons.forEach(btn => {
          btn.classList.remove('active', 'badge-pending');
          btn.classList.add('bg-white', 'text-gray-700', 'border', 'border-gray-300');
        });
        button.classList.add('active', 'badge-pending');
        button.classList.remove('bg-white', 'text-gray-700', 'border', 'border-gray-300');

        filterCards();
      });
    });

    // Practitioner filtering
    if (practitionerSelect) {
      practitionerSelect.addEventListener('change', () => {
        currentPractitioner = practitionerSelect.value;
        updateURL();
        filterCards();
      });
    }
  });
</script>