---
import Layout from '../components/Layout.astro';
import PlaceholderPage from '../components/PlaceholderPage.astro';
import { getCollection } from 'astro:content';
import { getBasePath } from '../lib/paths';
export const prerender = false;

// Check if site is in placeholder mode
const basePath = getBasePath();
const siteMode = import.meta.env.PUBLIC_SITE_MODE || 'full';
const isPlaceholder = siteMode === 'placeholder';

const services = await getCollection('services');

// Get upcoming events from markdown collection
const allEvents = await getCollection('events');
const now = new Date();
const upcomingEvents = allEvents
  .filter(event => event.data.featured && new Date(event.data.date) >= now)
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime())
  .slice(0, 3);

function formatEventDate(date: Date): string {
  const today = new Date();
  const tomorrow = new Date(today);
  tomorrow.setDate(tomorrow.getDate() + 1);
  
  const isToday = date.toDateString() === today.toDateString();
  const isTomorrow = date.toDateString() === tomorrow.toDateString();
  
  if (isToday) return 'Today';
  if (isTomorrow) return 'Tomorrow';
  
  return date.toLocaleDateString('en-US', { 
    month: 'short', 
    day: 'numeric',
    year: date.getFullYear() !== today.getFullYear() ? 'numeric' : undefined
  });
}

function formatEventTime(date: Date): string {
  return date.toLocaleTimeString('en-US', { 
    hour: 'numeric', 
    minute: '2-digit',
    timeZoneName: 'short'
  });
}
const featuredServices = [] as typeof services;
const maintainerServices = services.filter(service => 
  service.data.target_audience === 'maintainer' || service.data.target_audience === 'both'
);
const companyServices = services.filter(service => 
  service.data.target_audience === 'company' || service.data.target_audience === 'both'
);
---

<Layout 
  title="Open Future | A Grassroots Community of Practitioners" 
  description="A grassroots community of practitioners connecting to drive impact through sustainability, openness in AI, digital sovereignty, and beyond while supporting each other along the way.">
  {isPlaceholder ? (
    <PlaceholderPage />
  ) : (
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-gray-50 to-gray-100 py-12 pb-8" aria-labelledby="hero-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="max-w-4xl mx-auto">
        <h1 id="hero-heading" class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-950 mb-4">
          Open <span class="text-accent">Future</span>
        </h1>
        <p class="text-base md:text-lg lg:text-xl text-gray-700 mb-8">
          Independent community infrastructure for an open future
        </p>
        
        <!-- Community & Activities -->
        <div class="grid md:grid-cols-3 gap-6 mb-8" role="list">
          <article class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 flex flex-col" role="listitem">
            <h2 class="text-xl font-semibold text-purple-700 mb-2">Join the Community</h2>
            <p class="text-gray-700 mb-4 flex-grow">Connect with practitioners working on openness in AI, digital sovereignty, and beyond.</p>
            <a 
              href={`${basePath}helpers`} 
              class="btn-sparkle w-full"
              aria-label="Join the community"
            >
              <svg class="btn-sparkle-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
              <span class="btn-sparkle-text">Connect with Us</span>
              <span class="btn-sparkle-particles">
                <span class="sparkle-particle" style="top: 50%; left: 25%; background-color: rgb(196, 181, 253);"></span>
                <span class="sparkle-particle" style="top: 25%; right: 33%; background-color: rgb(167, 139, 250); animation-delay: 0.1s;"></span>
                <span class="sparkle-particle" style="bottom: 33%; right: 25%; background-color: rgb(217, 213, 254); animation-delay: 0.2s;"></span>
              </span>
            </a>
          </article>
          
          <article class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 flex flex-col" role="listitem">
            <h2 class="text-xl font-semibold text-purple-700 mb-2">Meetups and Workshops</h2>
            <p class="text-gray-700 mb-4 flex-grow">Join discussions and workshops. Share knowledge, learn from peers.</p>
            <a 
              href={`${basePath}calendar`}
              class="btn-sparkle w-full"
              aria-label="View community calendar"
            >
              <svg class="btn-sparkle-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span class="btn-sparkle-text">View Calendar</span>
              <span class="btn-sparkle-particles">
                <span class="sparkle-particle" style="top: 50%; left: 25%; background-color: rgb(196, 181, 253);"></span>
                <span class="sparkle-particle" style="top: 25%; right: 33%; background-color: rgb(167, 139, 250); animation-delay: 0.1s;"></span>
                <span class="sparkle-particle" style="bottom: 33%; right: 25%; background-color: rgb(217, 213, 254); animation-delay: 0.2s;"></span>
              </span>
            </a>
          </article>
          
          <article class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 flex flex-col" role="listitem">
            <h2 class="text-xl font-semibold text-purple-700 mb-2">OSS Wishlists</h2>
            <p class="text-gray-700 mb-4 flex-grow">Declare sustainability needs as wishlists. Connect with practitioners who can fulfill them through paid support.</p>
            <a 
              href={`${basePath}wishlists`} 
              class="btn-sparkle w-full"
              aria-label="Learn more about wishlists"
            >
              <svg class="btn-sparkle-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
              </svg>
              <span class="btn-sparkle-text">Learn more</span>
              <span class="btn-sparkle-particles">
                <span class="sparkle-particle" style="top: 50%; left: 25%; background-color: rgb(196, 181, 253);"></span>
                <span class="sparkle-particle" style="top: 25%; right: 33%; background-color: rgb(167, 139, 250); animation-delay: 0.1s;"></span>
                <span class="sparkle-particle" style="bottom: 33%; right: 25%; background-color: rgb(217, 213, 254); animation-delay: 0.2s;"></span>
              </span>
            </a>
          </article>
        </div>

      </div>
    </section>

    <!-- Upcoming Events Section -->
    {upcomingEvents.length > 0 && (
    <section class="bg-gradient-to-br from-purple-50 to-violet-50 py-10" aria-labelledby="events-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 id="events-heading" class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">Upcoming Events</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
          {upcomingEvents.map(event => {
            const eventDate = new Date(event.data.date);
            return (
              <article class="bg-white rounded-lg overflow-hidden shadow-md border-t-4 border-purple-500 hover:shadow-lg transition-shadow flex flex-col">
                {event.data.thumbnail && (
                  <img 
                    src={`${basePath}${event.data.thumbnail.startsWith('/') ? event.data.thumbnail.slice(1) : event.data.thumbnail}`}
                    alt={event.data.title}
                    class="w-full h-48 object-contain bg-gray-50 p-4"
                  />
                )}
                <div class="p-6 flex flex-col flex-grow">
                  <div class="mb-4">
                    <h3 class="font-bold text-gray-900 text-lg mb-2">{event.data.title}</h3>
                    <div class="flex items-center gap-2 text-sm text-purple-700 font-semibold">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                      {formatEventDate(eventDate)} • {formatEventTime(eventDate)}
                    </div>
                  </div>
                  <p class="text-gray-600 text-sm mb-6 flex-grow leading-relaxed">{event.data.description}</p>
                  <a 
                    href={event.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white text-sm font-semibold rounded-lg transition-colors mt-auto"
                  >
                    {event.data.buttonText}
                    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                  </a>
                </div>
              </article>
            );
          })}
        </div>
        <div class="mt-12 text-center">
          <a 
            href={`${basePath}calendar`}
            class="inline-flex items-center gap-2 text-purple-700 hover:text-purple-900 font-semibold text-lg"
          >
            View Full Calendar
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>
    )}
        </div>
      </div>
    </div>
  </section>
  )}
</Layout>
```