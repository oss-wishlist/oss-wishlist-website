---
import Layout from '../components/Layout.astro';
import PlaceholderPage from '../components/PlaceholderPage.astro';
import { getCollection } from 'astro:content';
import { getBasePath } from '../lib/paths';
export const prerender = false;

// Check if site is in placeholder mode
const basePath = getBasePath();
const siteMode = import.meta.env.PUBLIC_SITE_MODE || 'full';
const isPlaceholder = siteMode === 'placeholder';

const services = await getCollection('services');

const featuredServices = [] as typeof services;
const maintainerServices = services.filter(service => 
  service.data.target_audience === 'maintainer' || service.data.target_audience === 'both'
);
const companyServices = services.filter(service => 
  service.data.target_audience === 'company' || service.data.target_audience === 'both'
);
---

<Layout 
  title="Open Source Wishlist | Connecting Maintainers with Practitioners" 
  description="Open Source Wishlist connects open source maintainers with practitioners who can help with governance, funding, security, and more.">
  {isPlaceholder ? (
    <PlaceholderPage />
  ) : (
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-gray-50 to-gray-100 py-12 pb-8" aria-labelledby="hero-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="max-w-4xl mx-auto">
        <h1 id="hero-heading" class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-950 mb-4">
          Open Source <span class="text-accent">Wishlist</span>
        </h1>
        <p class="text-base md:text-lg lg:text-xl text-gray-700 mb-8">
          Connecting open source maintainers with practitioners who can help
        </p>
        
        <!-- Main Cards -->
        <div class="grid md:grid-cols-3 gap-6 mb-8" role="list">
          <article class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 flex flex-col" role="listitem">
            <h2 class="text-xl font-semibold text-purple-700 mb-2">Wishlists</h2>
            <p class="text-gray-700 mb-4 flex-grow">Maintainers can post specific needs and have them fulfilled through a practitioner, a funded contributor, or employee time from a supporting company.</p>
            <a 
              href={`${basePath}wishlists`} 
              class="btn-sparkle w-full"
              aria-label="Browse or create wishlists"
            >
              <svg class="btn-sparkle-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
              </svg>
              <span class="btn-sparkle-text">Wishlists</span>
              <span class="btn-sparkle-particles">
                <span class="sparkle-particle" style="top: 50%; left: 25%; background-color: rgb(196, 181, 253);"></span>
                <span class="sparkle-particle" style="top: 25%; right: 33%; background-color: rgb(167, 139, 250); animation-delay: 0.1s;"></span>
                <span class="sparkle-particle" style="bottom: 33%; right: 25%; background-color: rgb(217, 213, 254); animation-delay: 0.2s;"></span>
              </span>
            </a>
          </article>
          
          <article class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 flex flex-col" role="listitem">
            <h2 class="text-xl font-semibold text-purple-700 mb-2">Practitioners</h2>
            <p class="text-gray-700 mb-4 flex-grow">Independent open source experts ready to take on a wish from a project that needs their skills.</p>
            <a 
              href={`${basePath}practitioners`}
              class="btn-sparkle w-full"
              aria-label="View practitioners"
            >
              <svg class="btn-sparkle-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
              <span class="btn-sparkle-text">View Practitioners</span>
              <span class="btn-sparkle-particles">
                <span class="sparkle-particle" style="top: 50%; left: 25%; background-color: rgb(196, 181, 253);"></span>
                <span class="sparkle-particle" style="top: 25%; right: 33%; background-color: rgb(167, 139, 250); animation-delay: 0.1s;"></span>
                <span class="sparkle-particle" style="bottom: 33%; right: 25%; background-color: rgb(217, 213, 254); animation-delay: 0.2s;"></span>
              </span>
            </a>
          </article>
          
          <article class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 flex flex-col" role="listitem">
            <h2 class="text-xl font-semibold text-purple-700 mb-2">Catalog of Services</h2>
            <p class="text-gray-700 mb-4 flex-grow">Services with defined outcomes and rubrics, so projects know what they are getting and funders can see the impact of their investment.</p>
            <a 
              href={`${basePath}catalog`} 
              class="btn-sparkle w-full"
              aria-label="Explore services catalog"
            >
              <svg class="btn-sparkle-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
              <span class="btn-sparkle-text">Explore Services Catalog</span>
              <span class="btn-sparkle-particles">
                <span class="sparkle-particle" style="top: 50%; left: 25%; background-color: rgb(196, 181, 253);"></span>
                <span class="sparkle-particle" style="top: 25%; right: 33%; background-color: rgb(167, 139, 250); animation-delay: 0.1s;"></span>
                <span class="sparkle-particle" style="bottom: 33%; right: 25%; background-color: rgb(217, 213, 254); animation-delay: 0.2s;"></span>
              </span>
            </a>
          </article>
        </div>

        <!-- Read More Link -->
        <p class="text-sm text-gray-600 mt-2">
          Read more about Open Source Wishlist &rarr;
          <a
            href="https://sunnydeveloper.com/open-source-wishlist-community-infrastructure-for-oss-sustainability/"
            target="_blank"
            rel="noopener noreferrer"
            class="link-secondary font-medium"
          >Open Source Wishlist: Community Infrastructure for OSS Sustainability</a>
        </p>

      </div>
    </section>

        </div>
      </div>
    </div>
  </section>
  )}
</Layout>
```